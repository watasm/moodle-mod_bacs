<div id="view-task-dynamics" class="bacs-view">
    <div class="d-flex flex-wrap align-items-center justify-content-center mb-4">
        
        <div class="d-flex align-items-center me-md-3 me-3 mb-3">
            <label for="task-dynamics-select" class="me-2 fw-bold text-muted text-nowrap">
                {{#str}} select_task, mod_bacs {{/str}}:
            </label>
            <select id="task-dynamics-select" class="form-select form-select-sm w-auto shadow-sm" style="min-width: 150px;">
                <option value="-1">All Tasks</option>
                {{#tasks_for_template}}
                    <option value="{{task_id}}">{{task_order}}. {{name}}</option>
                {{/tasks_for_template}}
            </select>
        </div>
        
        <div class="d-flex align-items-center mb-3">
            <label for="student-dynamics-select" class="me-2 fw-bold text-muted text-nowrap">Participant:</label>
            <select id="student-dynamics-select" class="form-select form-select-sm w-auto shadow-sm" style="min-width: 180px; max-width: 300px;">
                <option value="-1">All Participants</option>
            </select>
        </div>
    </div>

    <div id="task-stats-info" class="text-center mb-4"></div>

    <div class="position-relative" style="min-height: 400px;">
        <canvas id="task-dynamics-chart" style="max-height: 600px;" class="d-none"></canvas>
        
        <div id="task-dynamics-placeholder" class="chart-placeholder d-none">
        </div>
    </div>

    <div id="task-click-details" class="mt-4 shadow-sm" style="display: none; background: #fff; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="m-0" id="task-details-title" style="color: #333;"></h5>
            <button type="button" class="btn-close" onclick="document.getElementById('task-click-details').style.display='none'" aria-label="Close"></button>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover" id="task-details-table">
                <thead class="table-light">
                    <tr>
                        <th>Time</th>
                        <th>User</th>
                        <th>Task</th>
                        <th>Verdict</th>
                        <th>Points</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<style>
    #view-task-dynamics .form-select {
        border-color: #ced4da;
    }
    @media (min-width: 768px) {
        #view-task-dynamics .me-md-5 {
            margin-right: 3rem !important;
        }
    }
</style>