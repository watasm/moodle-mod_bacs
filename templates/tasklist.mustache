<script>
    window.bacsWsAvailable = false;

    async function sendSolutionInBg(formElement, taskId, taskOrder) {
        const btnSend = document.getElementById('sendbutton' + taskOrder);
        const btnLock = document.getElementById('sendbuttonlocked' + taskOrder);
        const successMsg = document.getElementById('success_msg_task_' + taskId);
        
        btnSend.classList.add('d-none');
        btnLock.classList.remove('d-none');
        if (successMsg) successMsg.classList.add('d-none');

        const formData = new FormData(formElement);

        try {
            const response = await fetch('ajax_submit.php', { method: 'POST', body: formData });
            const data = await response.json();

            if (data.status === 'ok') {
                if (successMsg) successMsg.classList.remove('d-none'); 
                
                const taskRow = document.getElementById('task_row_' + taskId);
                const isAlreadyAccepted = taskRow && taskRow.classList.contains('verdict-accepted');
                
                if (!isAlreadyAccepted) {
                    if (taskRow) {
                        taskRow.classList.remove('verdict-failed', 'verdict-accepted');
                        taskRow.classList.add('verdict-none');
                    }
                    const statusSpan = document.getElementById('task_status_' + taskId);
                    if (statusSpan) {
                        let spinnerHtml = '';
                        if (window.bacsWsAvailable) {
                            spinnerHtml = ' <svg class="bi bi-arrow-repeat spin" width="1em" height="1em" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M2.854 7.146a.5.5 0 0 0-.708 0l-2 2a.5.5 0 1 0 .708.708L2.5 8.207l1.646 1.647a.5.5 0 0 0 .708-.708l-2-2zm13-1a.5.5 0 0 0-.708 0L13.5 7.793l-1.646-1.647a.5.5 0 0 0-.708.708l2 2a.5.5 0 0 0 .708 0l2-2a.5.5 0 0 0 0-.708z"/><path fill-rule="evenodd" d="M8 3a4.995 4.995 0 0 0-4.192 2.273.5.5 0 0 1-.837-.546A6 6 0 0 1 14 8a.5.5 0 0 1-1.001 0 5 5 0 0 0-5-5zM2.5 7.5A.5.5 0 0 1 3 8a5 5 0 0 0 9.192 2.727.5.5 0 1 1 .837.546A6 6 0 0 1 2 8a.5.5 0 0 1 .501-.5z"/></svg>';
                        }
                        statusSpan.innerHTML = '{{#str}} submit_verdict_1, mod_bacs {{/str}}' + spinnerHtml;
                    }
                    
                    const statusIcon = document.getElementById('task_status_icon_' + taskId);
                    if (statusIcon) statusIcon.classList.add('d-none');
                    const statusLink = document.getElementById('task_status_link_' + taskId);
                    if (statusLink) statusLink.classList.add('disabled-link');
                }

                btnLock.classList.add('d-none');
                btnSend.classList.remove('d-none', 'btn-success');
                btnSend.classList.add('btn-secondary');
                btnSend.disabled = true;
                btnSend.innerHTML = '<i class="bi bi-check-lg"></i>';

                if (window.bacsSocket && window.bacsWsAvailable) {
                    window.bacsSocket.emit('watch_submits', [data.submit_id]);
                } else {
                    if (successMsg) {
                        successMsg.innerHTML = '{{#str}} solutionsentwait, mod_bacs {{/str}} <br><small><b>{{#str}} ws_offline_fallback, mod_bacs {{/str}}</b></small>';
                    }
                }
                return;
            } else {
                alert('{{#str}} error {{/str}}: ' + data.msg);
            }
        } catch (err) {
            alert('{{#str}} networkerror, mod_bacs {{/str}}');
        }

        btnSend.classList.remove('d-none');
        btnLock.classList.add('d-none');
    }
</script>

{{#ws_url}}
<script>
    function handleWsFallback() {
        window.bacsWsAvailable = false;
        const infoEl = document.getElementById('ws-fallback-info');
        if (infoEl) infoEl.classList.remove('d-none');
    }

    document.addEventListener("DOMContentLoaded", function() {
        setTimeout(function() {
            function setupSocket(ioFunc) {
                window.bacsSocket = ioFunc('{{ws_url}}', {
                    auth: { token: '{{ws_jwt}}' },
                    reconnectionAttempts: 2,
                    timeout: 5000
                });

                window.bacsSocket.on('connect', () => {
                    window.bacsWsAvailable = true;
                    const infoEl = document.getElementById('ws-fallback-info');
                    if (infoEl) infoEl.classList.add('d-none');
                });

                window.bacsSocket.on('connect_error', () => handleWsFallback());
                window.bacsSocket.on('disconnect', () => handleWsFallback());
                
                window.bacsSocket.on('submit_update', (data) => {
                    const row = document.getElementById('task_row_' + data.task_id);
                    if (row) {
                        const successMsg = document.getElementById('success_msg_task_' + data.task_id);
                        if (successMsg) successMsg.classList.add('d-none');

                        const isCurrentlyAccepted = row.classList.contains('verdict-accepted');
                        const isIncomingAccepted = data.verdict_css_class === 'verdict-accepted';

                        if (!isCurrentlyAccepted || isIncomingAccepted) {
                            row.classList.remove('verdict-none', 'verdict-accepted', 'verdict-failed');
                            if (data.verdict_css_class) row.classList.add(data.verdict_css_class);
                            
                            const statusEl = document.getElementById('task_status_' + data.task_id);
                            if (statusEl) statusEl.innerHTML = data.verdict_formatted;

                            const statusLink = document.getElementById('task_status_link_' + data.task_id);
                            if (statusLink) {
                                statusLink.href = 'results_for_submit.php?id={{coursemodule_id}}&submit_id=' + data.submit_id;
                                statusLink.classList.remove('disabled-link');
                                
                                const icon = document.getElementById('task_status_icon_' + data.task_id);
                                if (icon) icon.classList.remove('d-none');
                            }
                        }
                        
                        const pointsEl = document.getElementById('task_points_' + data.task_id);
                        if (pointsEl) {
                            const currentPoints = parseInt(pointsEl.innerHTML) || 0;
                            const newPoints = parseInt(data.points) || 0;
                            pointsEl.innerHTML = Math.max(currentPoints, newPoints);
                        }

                        if (data.verdict_css_class !== 'verdict-none') {
                            const form = document.getElementById('form_' + data.task_id);
                            if (form) {
                                const btnSend = form.querySelector('button[type="submit"]');
                                const btnLock = form.querySelector('button[id^="sendbuttonlocked"]');
                                if (btnSend) {
                                    btnSend.disabled = false;
                                    btnSend.classList.remove('d-none', 'btn-secondary');
                                    btnSend.classList.add('btn-success');
                                    btnSend.innerHTML = '{{#str}}send, mod_bacs{{/str}}';
                                }
                                if (btnLock) btnLock.classList.add('d-none');
                            }

                            if (data.verdict_css_class === 'verdict-accepted') {
                                const toggleCell = row.querySelector('.custom-row-collapse-icon');
                                if (toggleCell && !toggleCell.classList.contains('collapsed')) {
                                    toggleCell.click(); 
                                }
                            }
                        }
                    }
                });
            }

            if (typeof require !== 'undefined') {
                require(['{{ws_url}}/socket.io/socket.io.js'], function(ioModule) {
                    if (typeof ioModule !== 'undefined') {
                        setupSocket(ioModule);
                    } else if (typeof io !== 'undefined') {
                        setupSocket(io);
                    } else {
                        handleWsFallback();
                    }
                }, function(err) {
                    handleWsFallback();
                });
            } else {
                const wsScript = document.createElement('script');
                wsScript.src = '{{ws_url}}/socket.io/socket.io.js';
                wsScript.onload = function() {
                    if (typeof io !== 'undefined') setupSocket(io);
                    else handleWsFallback();
                };
                wsScript.onerror = handleWsFallback;
                document.head.appendChild(wsScript);
            }
        }, 200);
    });
</script>
{{/ws_url}}

<script>
document.addEventListener("DOMContentLoaded", function() {
    const urlParams = new URLSearchParams(window.location.search);
    const targetTaskId = urlParams.get('task_id');
    
    if (targetTaskId) {
        const targetRow = document.getElementById('task_row_' + targetTaskId);
        if (targetRow) {
            Array.from(targetRow.children).forEach(td => {
                td.style.transition = "background-color 0.2s";
                td.style.setProperty("background-color", "rgba(0, 123, 255, 0.08)", "important");
            });
            
            setTimeout(() => { 
                Array.from(targetRow.children).forEach(td => {
                    td.style.removeProperty("background-color");
                });
            }, 600);
        }

        urlParams.delete('task_id');
        let newUrl = window.location.pathname;
        if (urlParams.toString()) newUrl += '?' + urlParams.toString();
        window.history.replaceState(null, '', newUrl + window.location.hash);
    }
});
</script>

