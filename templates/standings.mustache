{{! Load Libraries }}
<script type='text/javascript' src='{{config.wwwroot}}/mod/bacs/thirdparty/chart.umd.js'></script>
<script type='text/javascript' src='{{config.wwwroot}}/mod/bacs/thirdparty/chartjs-plugin-zoom.min.js'></script>
<script type='text/javascript' src='standings.js'></script>

<script type='text/javascript'>
    window.BACS_PAGE_DATA = {
        submissions: {{{submits_json}}},
        students: {{{students_json}}},
        tasks: {{{tasks_json}}},
        contest: {
            starttime: {{starttime}},
            endtime: {{endtime}},
            localizedStrings: {{{localized_strings_json}}}
        }
    };
</script>

{{! Load Modular Scripts (Adjust paths relative to your wwwroot/mod/bacs/js-charts/) }}
<script type='text/javascript' src='js-charts/bacs_utils.js'></script>
<script type='text/javascript' src='js-charts/chart_leader_dynamics.js'></script>
<script type='text/javascript' src='js-charts/chart_results.js'></script>
<script type='text/javascript' src='js-charts/chart_task_dynamics.js'></script>
<script type='text/javascript' src='js-charts/bacs_main.js'></script>

{{! Buttons to toggle between different views }}
<div class="bacs-view-toggles btn-group mb-3" role="group" aria-label="View toggles">
    <button type="button" class="btn btn-primary active" data-view="monitor"><i class="bi bi-table"></i> {{#str}} view_monitor, mod_bacs {{/str}}</button>
    <button type="button" class="btn btn-secondary" data-view="leader-dynamics"><i class="bi bi-graph-up-arrow"></i> {{#str}} view_leaderdynamics, mod_bacs {{/str}}</button>
    <button type="button" class="btn btn-secondary" data-view="results-graph"><i class="bi bi-bar-chart"></i> {{#str}} view_resultsgraph, mod_bacs {{/str}}</button>
    <button type="button" class="btn btn-secondary" data-view="task-dynamics"><i class="bi bi-pie-chart"></i> {{#str}} view_taskdynamics, mod_bacs {{/str}}</button>
</div>

{{! Container for all views - now populated with partials }}
<div class="bacs-views-container">
    {{> mod_bacs/partials/standings_monitor }}
    {{> mod_bacs/partials/standings_leader_dynamics }}
    {{> mod_bacs/partials/standings_results_graph }}
    {{> mod_bacs/partials/standings_task_dynamics }}
</div>


{{! Original script for standings.js initialization. }}
<script type='text/javascript'>
    var standings = new Standings(
        {{{students_json}}}, 
        {{{tasks_json}}}, 
        {{{submits_json}}}, 
        {{coursemodule_id}}, 
        {{moodle_user_id}}, 
        {{starttime}},
        {{endtime}},
        {{mode}},
        false,
        false,
        {{#user_capability_viewany}} true {{/user_capability_viewany}}  {{^user_capability_viewany}} false {{/user_capability_viewany}},
        {{{localized_strings_json}}},
        {{{incidents_json}}}
    );
</script>

<script type="text/javascript">
document.addEventListener("DOMContentLoaded", function() {
    
    let sortDirection = 1;

    function enhanceStandingsTable() {
        const table = document.getElementById('standings_table');
        if (!table) return;

        const rows = table.querySelectorAll('tbody tr');
        rows.forEach(row => {
            const nameCells = row.querySelectorAll('td[data-user-id]'); 
            nameCells.forEach(nameCell => {
                if (!nameCell.querySelector('a.profile-link')) {
                    let subEl = nameCell.querySelector('sub');
                    let subHtml = subEl ? subEl.outerHTML : '';
                    if (subEl) subEl.remove();

                    let nameText = nameCell.textContent.trim();
                    let userId = nameCell.getAttribute('data-user-id');
                    
                    if (userId && nameText) {
                        nameCell.innerHTML = `<a href="/user/view.php?id=${userId}" target="_blank" class="profile-link" style="text-decoration: none; color: var(--bacs-primary-color, #0f6cbf); font-weight: 500;">
                            <i class="bi bi-person-circle text-muted me-1"></i> ${nameText}
                        </a> ${subHtml}`;
                    }
                }
            });
        });

        const headers = table.querySelectorAll('thead th');
        headers.forEach((th, index) => {
            if(th.classList.contains('sort-enabled')) return;
            
            th.classList.add('sort-enabled');
            th.style.cursor = 'pointer';
            th.title = "Нажмите для сортировки";
            
            if(!th.querySelector('.sort-icon')) {
                th.innerHTML += ' <i class="bi bi-arrow-down-up text-muted sort-icon" style="font-size: 0.7em; margin-left: 4px;"></i>';
            }

            th.addEventListener('click', () => {
                sortTable(table, index);
            });
        });
    }

    function sortTable(table, colIndex) {
        const tbody = table.querySelector('tbody');
        if(!tbody) return;
        
        const rows = Array.from(tbody.querySelectorAll('tr'));
        sortDirection = sortDirection * -1; 

        rows.sort((a, b) => {
            let cellA = a.cells[colIndex] ? a.cells[colIndex].textContent.trim() : "";
            let cellB = b.cells[colIndex] ? b.cells[colIndex].textContent.trim() : "";

            cellA = cellA.replace(/\[.*\]/g, '').trim();
            cellB = cellB.replace(/\[.*\]/g, '').trim();

            let numA = parseFloat(cellA);
            let numB = parseFloat(cellB);

            if (!isNaN(numA) && !isNaN(numB)) {
                return (numA - numB) * sortDirection;
            }
            
            return cellA.localeCompare(cellB) * sortDirection;
        });

        table.querySelectorAll('thead th i.sort-icon').forEach(i => i.className = 'bi bi-arrow-down-up text-muted sort-icon');
        const clickedIcon = table.querySelectorAll('thead th')[colIndex].querySelector('i.sort-icon');
        if (clickedIcon) {
            clickedIcon.className = sortDirection === 1 ? 'bi bi-caret-up-fill text-primary sort-icon' : 'bi bi-caret-down-fill text-primary sort-icon';
        }

        rows.forEach(row => tbody.appendChild(row));
    }

    const observer = new MutationObserver((mutations) => {
        observer.disconnect(); 
        enhanceStandingsTable();
        observer.observe(document.getElementById('standings_table'), { childList: true, subtree: true });
    });
    
    setTimeout(() => {
        const tbl = document.getElementById('standings_table');
        if(tbl) {
            enhanceStandingsTable();
            observer.observe(tbl, { childList: true, subtree: true });
        }
    }, 500);

});
</script>